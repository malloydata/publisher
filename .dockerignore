__cache__
node_modules
.git
.gitignore
*.md
dist
docker-compose.yaml
.prettierrc.json
.eslintrc.json
Readme.md
/.next/
/out/
vscode
github
.DS_Store
Dockerfile.*
.dockerignore

# Additional exclusions to reduce build context
*.log
*.tmp
*.temp
.cache
coverage
.nyc_output
.env*
!.env.example
.idea
.vscode
*.swp
*.swo
*~

# Exclude large directories that aren't needed for build
examples/
malloy-samples/
docs/
scripts/*
# Except the DuckDB extension baker, which the Dockerfile runs in the final
# stage (the same script `bun run build` uses locally and in CI). Exclude the
# directory contents with scripts/* (not scripts/) so this negation re-includes
# the one file -- Docker won't re-include from a dir pruned by a bare "scripts/".
!scripts/bake-duckdb-extensions.js
.github/

# Exclude development files
**/*.dev.*
**/*.local.*

