node_modules
.DS_Store

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
**/.env

# Log files
*.log

packages/server/k6-tests/clients/
packages/server/k6-tests/results/

# Playwright MCP artifacts
.playwright-mcp/*

# Playwright test run artifacts
packages/app/test-results/
packages/app/playwright-report/

# Publisher runtime artifacts (DuckDB metadata + per-env package clones).
# Created wherever the server is launched from; already covered by
# packages/server/.gitignore for the canonical launch location, but
# anyone running from the repo root (smoke tests, make publisher-start,
# Playwright via the webServer block) gets them here too.
publisher.db
publisher.db.wal
publisher_data/

# Credible-platform-specific artifacts must never be committed to this open-source
# repo. `credible-*` skills live only in the Credible source-of-truth repo; the copy
# into Publisher is by design limited to the neutral shared set (see skills/README.md).
# These are local Credible workflow files (an installed skill tree + IDE rules) and are
# ignored by the `credible-` prefix so a stray `git add` can't pull them in.
.credible/
.claude/skills/credible-*/
.claude/rules/credible-*.md
.cursor/rules/credible-*.mdc
